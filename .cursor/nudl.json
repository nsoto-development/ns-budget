{
  "version": 1,
  "layout": "app",
  "project": "ns-budget",
  "anchors": {
    "roadmap": "docs/roadmap.md",
    "mvpScope": "docs/mvp-scope.md",
    "workflow": "docs/process/cursor-workflow.md",
    "agentsIndex": "AGENTS.md",
    "featuresDir": "docs/features",
    "epicsDir": "docs/epics",
    "methodologyPlan": null
  },
  "disciplineGlobs": [
    "src/**/*",
    "app/**/*",
    "lib/**/*",
    "cli/**/*",
    "package.json",
    "pyproject.toml",
